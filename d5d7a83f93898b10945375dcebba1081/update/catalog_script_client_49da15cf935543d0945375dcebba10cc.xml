        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
	g_form.hideErrorBox('state');

	if (isLoading || newValue == '') {
      return;
   }
		
	if (newValue && validateState(newValue))
		g_form.showErrorBox('state', getMessage('Home state cannot start with a number'));
}

function validateState(state) { 
    var re = /^\d/;
    return re.test(state);
}]]></script>
