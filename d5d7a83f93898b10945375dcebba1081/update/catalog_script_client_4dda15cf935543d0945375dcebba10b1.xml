        <messages>Not a valid phone number</messages>
        <name>Validate and format home phone</name>
        <order/>
        <published_ref/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
	if (isLoading || newValue == '') {
		return;
	}
	g_form.hideErrorBox('home_phone');
	var number = newValue.replace('+', '%2B');
	$.get("/api/sn_hr_core/hr_rest_api/validatPhoneNumber?phoneNumber=" + number, function(answer) {
		if (answer) {
			var result = answer['result'];
			var val = JSON.parse(result);
			if (val.valid) {
				if (newValue != val.number)
					g_form.setValue('home_phone', val.number);
			} else
				g_form.showFieldMsg('home_phone', getMessage('Not a valid phone number'), 'error');			
		}
	});
}]]></script>
