        <script><![CDATA[function onLoad() {
    var url = this.document.URL;
    url = url.split("/");

    var tableIndexInUrl = url.indexOf("cmdb_application_product_model");
    var selectedTabIndexPos = url.indexOf("selected-tab-index");

    // If user is on product details page and initiation is from included products tab, set that product as parent
    if (tableIndexInUrl > -1 && selectedTabIndexPos > -1 && (url[selectedTabIndexPos + 1] == 4)) {
        // get product sys_id
        var productId = url[tableIndexInUrl + 1];
        g_form.setValue("parent_product", productId);
    }
}]]></script>
